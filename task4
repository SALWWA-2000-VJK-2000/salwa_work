//Task 289: Online Exam Platform

CLASS Question
	ATTRIBUTES
        PRIVATE text : TEXT
        PRIVATE correctAnswer : TEXT
        PRIVATE points : NUMBER
		
	CONSTRUCTOR(q : TEXT, ans : TEXT, p : NUMBER)
        SET text TO q
        SET correctAnswer TO ans
        SET points TO p
    END CONSTRUCTOR

    METHODS
        GET_POINTS()
            RETURN points
        END METHOD

        CHECK_ANSWER(a : TEXT)
            IF a EQUALS correctAnswer THEN
                RETURN TRUE
            ELSE
                RETURN FALSE
            END IF
        END METHOD
END CLASS

CLASS Answer
    ATTRIBUTES
        PRIVATE question : Question
        PRIVATE selectedAnswer : TEXT

    CONSTRUCTOR(q : Question, sa : TEXT)
        SET this.question TO q
        SET this.selectedAnswer TO sa
    END CONSTRUCTOR

    METHODS
        GET_QUESTION()
            RETURN question
        END METHOD

        GET_SELECTED()
            RETURN selectedAnswer
        END METHOD
END CLASS

CLASS Exam
    ATTRIBUTES
        PRIVATE title : TEXT
        PRIVATE questions : LIST<Question>
        PRIVATE timeLimit : NUMBER   

    CONSTRUCTOR(t : TEXT, tl : NUMBER)
        SET title TO t
        SET timeLimit TO tl
        SET questions TO LIST []
    END CONSTRUCTOR

    METHODS
        ADD_QUESTION(q : Question)
            ADD q TO questions
        END METHOD

        GET_TIME_LIMIT()
            RETURN timeLimit
        END METHOD
END CLASS


CLASS Student
    ATTRIBUTES
        PRIVATE name : TEXT
        PRIVATE attempts : LIST<Attempt>

    CONSTRUCTOR(n : TEXT)
        SET name TO n
        SET attempts TO LIST []
    END CONSTRUCTOR

    METHODS
        ADD_ATTEMPT(a : Attempt)
            ADD a TO attempts
        END METHOD

        VIEW_ATTEMPTS()
			SET i TO 0
			REPEAT WHILE i LESS THAN SIZE OF attempts
				SET attemptNumber TO i + 1
				DISPLAY "Attempt:" + attemptNumber + ": Score = " + attempts[i].score
				SET i TO i + 1
			END REPEAT
		END METHOD
END CLASS


CLASS Attempt
    ATTRIBUTES
        PRIVATE exam : Exam
        PRIVATE student : Student
        PRIVATE answers : LIST<TEXT>
        PRIVATE score : NUMBER
        PRIVATE startTime : NUMBER   
        PRIVATE timeLimit : NUMBER

    CONSTRUCTOR(e : Exam, s : Student, st : NUMBER)
        SET exam TO e
        SET student TO s
        SET startTime TO st
        SET timeLimit TO e.GET_TIME_LIMIT()
        SET answers TO LIST []
        SET score TO 0
    END CONSTRUCTOR

    METHODS
        ADD_ANSWER(a : TEXT, currentTime : NUMBER)
            IF currentTime - startTime GREATER THAN timeLimit THEN
                DISPLAY "Error: Time limit exceeded"
            ELSE
                ADD a TO answers
            END IF
        END METHOD

		CALCULATE_SCORE()
			SET total TO 0
			SET i TO 0
			REPEAT WHILE i LESS THAN SIZE OF answers
				IF answers[i].GET_QUESTION().CHECK_ANSWER(answers[i].GET_SELECTED()) EQUALS TRUE THEN
					SET total TO total + answers[i].GET_QUESTION().GET_POINTS()
				END IF
				SET i TO i + 1
			END REPEAT
			SET score TO total
			RETURN score
		END METHOD

END CLASS


START
	BEGIN
		CREATE OBJECT exam1 OF EXAM("Math Exam", 30)

		CREATE OBJECT q1 OF QUESTION("2+2?", "4", 5)
		CREATE OBJECT q2 OF QUESTION("5*3?", "15", 5)
		exam1.ADD_QUESTION(q1)
		exam1.ADD_QUESTION(q2)

		CREATE OBJECT student1 OF STUDENT("Ali")

		CREATE OBJECT attempt1 OF ATTEMPT(exam1, student1, 0)
		attempt1.ADD_ANSWER("4", 10)
		attempt1.ADD_ANSWER("15", 15)
		DISPLAY "Score: " + attempt1.CALCULATE_SCORE()

		student1.ADD_ATTEMPT(attempt1)

		CREATE OBJECT attempt2 OF ATTEMPT(exam1, student1, 40)
		attempt2.ADD_ANSWER("4", 75)   
		attempt2.ADD_ANSWER("12", 76)
		DISPLAY "Score: " + attempt2.CALCULATE_SCORE()

		student1.ADD_ATTEMPT(attempt2)

		student1.VIEW_ATTEMPTS()
	END
STOP


