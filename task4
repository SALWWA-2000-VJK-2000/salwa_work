CLASS Member
    ATTRIBUTES
        PRIVATE name : TEXT
        PRIVATE contactDetails : TEXT
        PRIVATE plan : MembershipPlan
        PRIVATE bookings : LIST<Booking>

    CONSTRUCTOR(n : TEXT, c : TEXT, p : MembershipPlan)
        SET name TO n
        SET contactDetails TO c
        SET plan TO p
        SET bookings TO LIST []
    END CONSTRUCTOR

    METHODS
		 GET_NAME()
            RETURN name
        END METHOD

        GET_CONTACT()
            RETURN contactDetails
        END METHOD
		
        ADD_BOOKING(b : Booking)
            ADD b TO bookings
        END METHOD

        CALCULATE_USED_HOURS()
            SET total TO 0
            SET i TO 0
            REPEAT WHILE i LESS THAN SIZE OF bookings
                SET total TO total + bookings[i].duration
                SET i TO i + 1
            END REPEAT
            RETURN total
        END METHOD

        CALCULATE_REMAINING_HOURS()
            RETURN plan.GET_QUOTA() - CALCULATE_USED_HOURS()
        END METHOD

        VIEW_BOOKINGS()
            SET i TO 0
            REPEAT WHILE i LESS THAN SIZE OF bookings
                SET bookingNumber TO i + 1
                DISPLAY "Booking #" + bookingNumber + ": Room " + bookings[i].room.name + 
                        " on " + bookings[i].date + " for " + bookings[i].duration + " hours"
                SET i TO i + 1
            END REPEAT
        END METHOD
END CLASS


CLASS Room
    ATTRIBUTES
        PRIVATE name : TEXT
        PRIVATE bookings : LIST<Booking>

    CONSTRUCTOR(n : TEXT)
        SET name TO n
        SET bookings TO LIST []
    END CONSTRUCTOR

    METHODS
		GET_NAME()
            RETURN name
        END METHOD
		
        IS_AVAILABLE(d : TEXT, start : NUMBER, end : NUMBER)
            SET i TO 0
            REPEAT WHILE i LESS THAN SIZE OF bookings
                IF bookings[i].date EQUALS d THEN
                    IF ((start LESS THAN bookings[i].endTime) AND (end GREATER THAN bookings[i].startTime) THEN
                        RETURN FALSE
                    END IF
                END IF
                SET i TO i + 1
            END REPEAT
            RETURN TRUE
        END METHOD

        ADD_BOOKING(b : Booking)
            ADD b TO bookings
        END METHOD
END CLASS


CLASS Booking
    ATTRIBUTES
        PRIVATE room : Room
        PRIVATE member : Member
        PRIVATE date : TEXT
        PRIVATE startTime : NUMBER
        PRIVATE endTime : NUMBER
        PRIVATE duration : NUMBER

    CONSTRUCTOR(r : Room, m : Member, d : TEXT, st : NUMBER, et : NUMBER)
        SET room TO r
        SET member TO m
        SET date TO d
        SET startTime TO st
        SET endTime TO et
        SET duration TO et - st
		IF duration LESS THAN OR EQUAL TO 0 THEN
			DISPLAY "Error: Invalid booking duration"
		END IF
    END CONSTRUCTOR

    METHODS
        CONFIRM()
			IF member.CALCULATE_USED_HOURS() + duration GREATER THAN member.plan.GET_QUOTA() THEN
				DISPLAY "Error: Booking exceeds member quota"
			ELSE IF room.IS_AVAILABLE(date, startTime, endTime) EQUALS FALSE THEN
				DISPLAY "Error: Room not available at this time"
			ELSE
				member.ADD_BOOKING(this)
				room.ADD_BOOKING(this)
				DISPLAY "Booking confirmed for " + member.GET_NAME() + " in room " + room.GET_NAME()
			END IF
		END METHOD

END CLASS


