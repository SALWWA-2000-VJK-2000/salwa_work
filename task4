		CREATE OBJECT plan1 OF MEMBERSHIPPLAN("Standard", 10)
		CREATE OBJECT member1 OF MEMBER("Ali", "99887766", plan1)
		CREATE OBJECT room1 OF ROOM("Meeting Room A")
		CREATE OBJECT booking1 OF BOOKING(room1, member1, "2026-07-10", 9, 11)
		booking1.CONFIRM()
		CREATE OBJECT booking2 OF BOOKING(room1, member1, "2026-07-10", 10, 12)
